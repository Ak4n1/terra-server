# Active profile
SPRING_PROFILES_ACTIVE=dev

# Server
SERVER_PORT=8080

# Database
# Option A: use host/port/name
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=terra_db
DB_USERNAME=terra_user
DB_PASSWORD=change_me

# Option B: use a full JDBC URL instead
# DB_URL=jdbc:mariadb://127.0.0.1:3306/terra_db

# Mail / SMTP
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=change_me
MAIL_FROM=noreply@example.com
APP_MAIL_FROM_NAME=L2 Terra
MAIL_SMTP_AUTH=true
MAIL_SMTP_SSL_ENABLE=true
MAIL_SMTP_STARTTLS_ENABLE=false
MAIL_SMTP_CONNECTION_TIMEOUT=10000
MAIL_SMTP_TIMEOUT=10000
MAIL_SMTP_WRITE_TIMEOUT=10000

# Frontend URLs used in email links
APP_MAIL_FRONTEND_VERIFY_URL=http://localhost:4200/verify-email
APP_MAIL_FRONTEND_RESET_PASSWORD_URL=http://localhost:4200/reset-password
APP_MAIL_VERIFICATION_EMAIL_COOLDOWN_SECONDS=60
APP_MAIL_PASSWORD_RESET_COOLDOWN_SECONDS=60

# JWT / Auth
JWT_SECRET=8c3f51d9a4b27e60f18c44d2be7f0a95c6d13e8b2f4a79c10d5e6f3a21b847cd
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=30
JWT_ACCESS_COOKIE_NAME=terra_access_token
JWT_REFRESH_COOKIE_NAME=terra_refresh_token
JWT_COOKIE_PATH=/

# CSRF
CSRF_COOKIE_NAME=XSRF-TOKEN
CSRF_HEADER_NAME=X-CSRF-TOKEN
CSRF_PATH=/
CSRF_SAME_SITE=Lax
CSRF_SECURE=false
CSRF_HTTP_ONLY=false

# CORS / network
APP_SECURITY_TRUST_FORWARDED_HEADERS=false
